# ── LLM Providers (al menos uno requerido por módulo, o usa Ollama local) ──
GROQ_API_KEY=your_groq_key_here        # free tier, generoso
OPENROUTER_API_KEY=your_key_here       # modelos :free disponibles
GOOGLE_API_KEY=your_gemini_key_here    # Gemini free tier
# OPENAI_API_KEY=                      # no requerido; módulos funcionan sin él

# ── Ollama (recomendado para CI local) ──
OLLAMA_BASE_URL=http://localhost:11434

# ── DeepEval / Confident AI (opcional, para dashboard online) ──
CONFIDENT_API_KEY=

# ── Langfuse (módulo 12, self-host) ──
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=http://localhost:3000

# ── Promptfoo (módulo 05) ──
# Usa los mismos providers de arriba; Promptfoo los detecta automáticamente

# ── Phoenix / Arize (módulo 12, alternativa a Langfuse) ──
PHOENIX_API_KEY=
PHOENIX_HOST=http://localhost:6006
